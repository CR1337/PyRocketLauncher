#!/bin/bash

export RED="\e[1;31m"
export CYAN="\e[1;36m"
export GREEN="\e[1;92m"
export RESET="\e[1;0m"

export BASE_DIR=/opt/rl
export APP_NAME="PyRocketLauncher"
export GITHUB_USER="CR1337"

info () {
    echo -e "${CYAN}INFO> $1 ${RESET}"
}
error () {
    >&2 echo -e "${RED}ERROR> $1 ${RESET}"
}
success() {
    echo -e "${GREEN}SUCCESS> $1 ${RESET}"
}
unexpected_error() {
    error "Unexpected error!"
    exit $1
}

if [ "$EUID" -ne 0 ]; then
    error "Please execute as root!"
    exit 1
fi

if [ -d "$BASE_DIR/$APP_NAME" ]; then
    error "$APP_NAME is already installed!"
    exit 1
fi

info "Creating base directory..."
mkdir -p $BASE_DIR
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi
info "Changing to base directory..."
cd $BASE_DIR
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Updating apt repositories..."
apt -y update
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Installing dependencies via apt..."
apt -y install git
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi
apt -y install python3
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi
apt -y install python3-pip
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi
apt -y install i2c-tools
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Enabling i²c..."
raspi-config nonint do_i2c 0
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Creating i²c user group..."
groupadd i2c
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Changing group ownership of i²c bus..."
chown :i2c /dev/i2c-1
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Changing permissions of i²c bus..."
chmod g+rw /dev/i2c-1
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Adding rl user to i²c group..."
usermod -aG i2c rl
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Making i²c permissions permanent..."
echo 'KERNEL=="i2c-[0-9]*", GROUP="i2c"' >> /etc/udev/rules.d/10-local_i2c_group.rules
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Cloning $APP_NAME repository from GitHub..."
git clone "https://github.com/$GITHUB_USER/$APP_NAME.git"
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Changing to app directory..."
cd $APP_NAME
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Changing ownership of app directory..."
chown -R rl:rl $BASE_DIR
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Installing dependencies via pip..."
python3 -m pip install --system -r requirements.txt
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Making logs directory..."
mkdir -p logs
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

info "Adding bin directory to PATH..."
PATH=$PATH:$BASE_DIR/$APP_NAME/bin
echo PATH=\$PATH:$BASE_DIR/$APP_NAME/bin >> /home/rl/.bashrc
ret_val=$?
if [ $ret_val -ne 0 ]; then
    unexpected_error $ret_val
fi

python3 ./bin/on_zero_w.py
ret_val=$?
if ! [ $ret_val -ne 0 ]; then
    info "Disabling onboard WiFi if on Pi Zero W (reboot needed)..."
    python3 ./bin/zero_wifi_off.py
    if [ $ret_val -ne 0 ]; then
        unexpected_error $ret_val
    fi
fi

success "Done"
